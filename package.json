{
    "name": "clonecord",
    "version": "1.0.0",
    "description": "A Vencord plugin that allows you to clone Discord servers",
    "author": "6jt8",
    "license": "AGPL-3.0-only",
    "repository": {
        "type": "git",
        "url": "https://github.com/6jt8/Clonecord.git"
    },
    "keywords": [
        "vencord",
        "discord",
        "plugin",
        "clone",
        "server"
    ],
    "type": "module",
    "private": true,
    "scripts": {
        "typecheck": "tsc --noEmit",
        "test": "vitest run",
        "test:watch": "vitest",
        "lint": "eslint .",
        "lint:fix": "eslint . --fix",
        "format": "prettier --write .",
        "format:check": "prettier --check .",
        "check": "npm run typecheck && npm run lint && npm run format:check && npm run test"
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@types/node": "^20.11.0",
        "@types/react": "^19.0.10",
        "@vencord/discord-types": "^1.0.0",
        "eslint": "^10.7.0",
        "eslint-config-prettier": "^10.1.8",
        "prettier": "^3.9.5",
        "typescript": "^7.0.2",
        "typescript-eslint": "^8.64.0",
        "vitest": "^4.1.10"
    }
}
